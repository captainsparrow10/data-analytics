{
  "name": "Data Analysis Environment",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  
  // Sin features externas — instalamos Poetry manualmente
  "features": {},

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        // 🌟 Le dice a VS Code que use el entorno virtual que creará Poetry
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python"
      }
    }
  },
  
  // Poetry ya viene instalado en la imagen — solo instala dependencias
  "postCreateCommand": "poetry config virtualenvs.in-project true && poetry install --no-root"
}